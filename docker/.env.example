# Production example for docker/production.docker-compose.yml
# Copy to docker/.env and change every password before deployment.

# App
# Use 0.0.0.0 when you want users to reach Langflow directly over the server IP/domain.
# If you put Nginx/Caddy in front, you can switch this back to 127.0.0.1.
LANGFLOW_BIND_ADDRESS=0.0.0.0
LANGFLOW_PORT=7860
LOG_LEVEL=INFO
LANGFLOW_AUTO_LOGIN=false
LANGFLOW_SKIP_AUTH_AUTO_LOGIN=false
API_KEY=

# Public URL used for signed media/file links.
# For direct beta access without HTTPS, use http://your-server-ip:7860 or http://your-domain:7860.
# Keep the trailing slash optional.
LANGFLOW_PUBLIC_BASE_URL=http://your-server-ip-or-domain:7860
# Backward-compatible alias still supported by the backend.
BACKEND_URL=

# Cookie/CORS settings for browser users.
# Direct HTTP beta deployment: keep both Secure flags false.
# Behind HTTPS reverse proxy: set both Secure flags to true and update the public URL/origin to https://...
LANGFLOW_ACCESS_SECURE=false
LANGFLOW_REFRESH_SECURE=false
LANGFLOW_ACCESS_SAME_SITE=lax
LANGFLOW_REFRESH_SAME_SITE=lax
# If frontend and API share the same origin, set this to that public origin.
LANGFLOW_CORS_ORIGINS=http://your-server-ip-or-domain:7860

# PostgreSQL
POSTGRES_USER=langflow
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=langflow

# Admin account
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=change-this-admin-password

# Security
SECRET_KEY=change-this-to-a-random-32-byte-secret

# Example HTTPS override:
# LANGFLOW_BIND_ADDRESS=127.0.0.1
# LANGFLOW_PUBLIC_BASE_URL=https://your-app-domain.example.com
# LANGFLOW_CORS_ORIGINS=https://your-app-domain.example.com
# LANGFLOW_ACCESS_SECURE=true
# LANGFLOW_REFRESH_SECURE=true

# Object storage
LANGFLOW_STORAGE_TYPE=minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_BUCKET=langflow-assets
MINIO_REGION=us-east-1
MINIO_ROOT_PREFIX=prod
MINIO_PRESIGN_EXPIRATION=3600

# Optional:
# If you put MinIO behind a domain/CDN and want direct public object URLs, set this.
# Otherwise Langflow will serve signed proxy URLs through LANGFLOW_PUBLIC_BASE_URL / BACKEND_URL.
MINIO_PUBLIC_BASE_URL=

# Provider keys
VOLCENGINE_API_KEY=
VOLCENGINE_ENDPOINT=
DASHSCOPE_API_KEY=
ARK_API_KEY=
ARK_API_BASE=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
SORA_API_BASE=
KLING_API_KEY=
KLING_API_BASE=
VIDU_API_KEY=
VIDU_API_BASE=
JIMENG_CV_ACCESS_KEY=
JIMENG_CV_SECRET_KEY=
JIMENG_VISUAL_API_BASE=https://visual.volcengineapi.com
