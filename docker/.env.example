# Production example for docker/production.docker-compose.yml
# Copy to docker/.env and change every password before deployment.

# App
LANGFLOW_PORT=7860
LOG_LEVEL=INFO
BACKEND_URL=http://localhost:7860/
LANGFLOW_AUTO_LOGIN=false
LANGFLOW_SKIP_AUTH_AUTO_LOGIN=true
API_KEY=
API_KEY_ENABLED=false

# PostgreSQL
POSTGRES_USER=langflow
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=langflow
POSTGRES_PORT_EXTERNAL=5433

# Admin account
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=change-this-admin-password

# Security
SECRET_KEY=change-this-to-a-random-32-byte-secret

# Object storage
LANGFLOW_STORAGE_TYPE=minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_BUCKET=langflow-assets
MINIO_REGION=us-east-1
MINIO_ROOT_PREFIX=prod
MINIO_PRESIGN_EXPIRATION=3600
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Optional:
# If you put MinIO behind a domain/CDN and want direct public object URLs, set this.
# Otherwise Langflow will serve signed proxy URLs through BACKEND_URL.
MINIO_PUBLIC_BASE_URL=

# Provider keys
VOLCENGINE_API_KEY=
VOLCENGINE_ENDPOINT=
DASHSCOPE_API_KEY=
ARK_API_KEY=
ARK_API_BASE=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
SORA_API_BASE=
KLING_API_KEY=
KLING_API_BASE=
VIDU_API_KEY=
VIDU_API_BASE=
JIMENG_CV_ACCESS_KEY=
JIMENG_CV_SECRET_KEY=
JIMENG_VISUAL_API_BASE=https://visual.volcengineapi.com
