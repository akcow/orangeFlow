# Production-ready example for docker/production.docker-compose.yml
# Copy to docker/.env and replace every placeholder before first launch.

# App bind
# Default to 0.0.0.0 so beta users can reach the service immediately after docker compose up.
# If you front OrangeFlow with Nginx/Caddy, switch this to 127.0.0.1.
LANGFLOW_BIND_ADDRESS=0.0.0.0
LANGFLOW_PORT=7860
COMPOSE_PROFILES=
NGINX_BIND_ADDRESS=0.0.0.0
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
LOG_LEVEL=INFO

# Public browser origin / signed media links
# Direct HTTP beta example:
LANGFLOW_PUBLIC_BASE_URL=http://your-server-ip-or-domain:7860
LANGFLOW_CORS_ORIGINS=http://your-server-ip-or-domain:7860

# Auth / browser cookies
LANGFLOW_AUTO_LOGIN=false
LANGFLOW_SKIP_AUTH_AUTO_LOGIN=false
LANGFLOW_ACCESS_SECURE=false
LANGFLOW_REFRESH_SECURE=false
LANGFLOW_ACCESS_SAME_SITE=lax
LANGFLOW_REFRESH_SAME_SITE=lax

# HTTPS reverse proxy override example:
# COMPOSE_PROFILES=https-proxy
# LANGFLOW_BIND_ADDRESS=127.0.0.1
# LANGFLOW_PUBLIC_BASE_URL=https://app.example.com
# LANGFLOW_CORS_ORIGINS=https://app.example.com
# LANGFLOW_ACCESS_SECURE=true
# LANGFLOW_REFRESH_SECURE=true
# Provide docker/ssl/cert.pem and docker/ssl/key.pem before enabling https-proxy.

# Database
POSTGRES_USER=orangeflow
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=orangeflow

# Superuser bootstrap
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=replace-with-a-strong-admin-password

# Signing / encryption
SECRET_KEY=replace-with-a-random-long-secret

# Object storage
LANGFLOW_STORAGE_TYPE=minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-strong-minio-password
MINIO_BUCKET=orangeflow-assets
MINIO_REGION=us-east-1
MINIO_ROOT_PREFIX=prod
MINIO_PRESIGN_EXPIRATION=3600

# Optional direct object CDN/domain. Leave empty to use signed OrangeFlow proxy URLs.
MINIO_PUBLIC_BASE_URL=

# Optional hardening / privacy
# LANGFLOW_DO_NOT_TRACK=true
# LANGFLOW_LOG_FILE=/app/orangeflow_config/logs/orangeflow.log

# Provider keys
VOLCENGINE_API_KEY=
VOLCENGINE_ENDPOINT=
DASHSCOPE_API_KEY=
ARK_API_KEY=
ARK_API_BASE=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
SORA_API_BASE=
KLING_API_KEY=
KLING_API_BASE=
VIDU_API_KEY=
VIDU_API_BASE=
JIMENG_CV_ACCESS_KEY=
JIMENG_CV_SECRET_KEY=
JIMENG_VISUAL_API_BASE=https://visual.volcengineapi.com
