# ============================================
# Langflow 生产环境配置文件
# ============================================
# 重要: 部署前请修改以下默认密码和密钥!

# ------------------------------------------
# Langflow 基础配置
# ------------------------------------------
LANGFLOW_PORT=7860
LOG_LEVEL=INFO

# ------------------------------------------
# 数据库配置
# ------------------------------------------
POSTGRES_USER=langflow
POSTGRES_PASSWORD=langflow_db_password_123!  # 请修改为强密码
POSTGRES_DB=langflow
POSTGRES_PORT=5432

# ------------------------------------------
# 管理员账户配置
# ------------------------------------------
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=admin_password_456!  # 请修改为强密码

# ------------------------------------------
# 安全配置
# ------------------------------------------
# 重要: 请修改为随机生成的强密钥
# 生成方法: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# ------------------------------------------
# API 配置
# ------------------------------------------
# 是否启用 API Key 验证
API_KEY_ENABLED=false
# API Key (如果启用验证)
API_KEY=

# ------------------------------------------
# 可选配置
# ------------------------------------------
# 是否跳过自动登录
SKIP_AUTO_LOGIN=True

# ------------------------------------------
# 资源限制
# ------------------------------------------
# Langflow 容器资源限制
LANGFLOW_MEMORY_LIMIT=4G
LANGFLOW_MEMORY_RESERVATION=2G
LANGFLOW_CPU_LIMIT=2
LANGFLOW_CPU_RESERVATION=1

# PostgreSQL 资源限制
POSTGRES_MEMORY_LIMIT=1G
POSTGRES_CPU_LIMIT=0.5
