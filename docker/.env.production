# ============================================
# Langflow production env template
# ============================================

# ------------------------------------------
# Langflow
# ------------------------------------------
LANGFLOW_PORT=7860
LOG_LEVEL=INFO

# ------------------------------------------
# Database (pgvector Postgres)
# ------------------------------------------
POSTGRES_USER=langflow
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=langflow
# If host 5432 is occupied, keep 5433; if you don't need host access, you can remove the postgres ports mapping in compose.
POSTGRES_PORT=5433

# ------------------------------------------
# Admin user
# ------------------------------------------
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=change-me-to-a-strong-password

# ------------------------------------------
# Security
# ------------------------------------------
# Generate: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# ------------------------------------------
# API
# ------------------------------------------
API_KEY_ENABLED=false
API_KEY=

# ------------------------------------------
# Optional
# ------------------------------------------
SKIP_AUTO_LOGIN=true
