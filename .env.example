# Description: Example of .env file
# Usage: Copy this file to .env and change the values
#        according to your needs
#        Do not commit .env file to git
#        Do not change .env.example file

# Config directory
# Directory where files, logs and database will be stored
# Example: LANGFLOW_CONFIG_DIR=~/.orangeflow
LANGFLOW_CONFIG_DIR=

# Save database in the config directory
# Values: true, false
# If false, the database will be saved in OrangeFlow's root directory
# This means that the database will be deleted when OrangeFlow is uninstalled
# and that the database will not be shared between different virtual environments
# Example: LANGFLOW_SAVE_DB_IN_CONFIG_DIR=true
LANGFLOW_SAVE_DB_IN_CONFIG_DIR=

# Database URL
# Recommended local Postgres example:
LANGFLOW_DATABASE_URL=postgresql://orangeflow:orangeflow@127.0.0.1:5433/orangeflow

# Optional local Postgres defaults used by start_service.py when LANGFLOW_DATABASE_URL is unset.
POSTGRES_USER=orangeflow
POSTGRES_PASSWORD=orangeflow
POSTGRES_DB=orangeflow
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Database connection retry
# Values: true, false
# If true, the database will retry to connect to the database if it fails
# Example: LANGFLOW_DATABASE_CONNECTION_RETRY=true
LANGFLOW_DATABASE_CONNECTION_RETRY=false

# Storage backend
# local: single-machine development or single-node beta only
# s3/minio: recommended for commercial or multi-instance deployments
LANGFLOW_STORAGE_TYPE=local

# S3 / MinIO object storage settings
LANGFLOW_S3_BUCKET_NAME=
LANGFLOW_S3_REGION=
LANGFLOW_S3_ENDPOINT_URL=
LANGFLOW_S3_ACCESS_KEY_ID=
LANGFLOW_S3_SECRET_ACCESS_KEY=
LANGFLOW_S3_SESSION_TOKEN=
LANGFLOW_S3_ROOT_PREFIX=
LANGFLOW_S3_PUBLIC_BASE_URL=
LANGFLOW_S3_PRESIGN_EXPIRATION=3600
LANGFLOW_S3_ADDRESSING_STYLE=path
LANGFLOW_S3_USE_SSL=true
LANGFLOW_S3_VERIFY_SSL=true

# Cache type
LANGFLOW_LANGCHAIN_CACHE=SQLiteCache

# Server host
# Example: LANGFLOW_HOST=localhost
LANGFLOW_HOST=

# Worker processes
# Example: LANGFLOW_WORKERS=1
LANGFLOW_WORKERS=

# Server port
# Example: LANGFLOW_PORT=7860
LANGFLOW_PORT=

# Logging level
# Example: LANGFLOW_LOG_LEVEL=critical
LANGFLOW_LOG_LEVEL=

# Path to the log file
# Example: LANGFLOW_LOG_FILE=logs/orangeflow.log
LANGFLOW_LOG_FILE=

# Inline video base64 size limit in bytes (set 0 to disable inline base64)
# Example: LANGFLOW_VIDEO_INLINE_MAX_BYTES=5242880
LANGFLOW_VIDEO_INLINE_MAX_BYTES=

# Time/Size for log to rotate
# Example: LANGFLOW_LOG_ROTATION=‘10 MB’/‘1 day’
LANGFLOW_LOG_ROTATION=

# Path to the frontend directory containing build files
# Example: LANGFLOW_FRONTEND_PATH=/path/to/frontend/build/files
LANGFLOW_FRONTEND_PATH=

# Whether to open the browser after starting the server
# Values: true, false
# Example: LANGFLOW_OPEN_BROWSER=true
LANGFLOW_OPEN_BROWSER=

# Whether to remove API keys from the projects saved in the database
# Values: true, false
# Example: LANGFLOW_REMOVE_API_KEYS=false
LANGFLOW_REMOVE_API_KEYS=

# Whether to use RedisCache or ThreadingInMemoryCache or AsyncInMemoryCache
# Values: async, memory, redis
# Example: LANGFLOW_CACHE_TYPE=memory
# If you want to use redis then the following environment variables must be set:
# LANGFLOW_REDIS_HOST (default: localhost)
# LANGFLOW_REDIS_PORT (default: 6379)
# LANGFLOW_REDIS_DB (default: 0)
# LANGFLOW_REDIS_CACHE_EXPIRE (default: 3600)
LANGFLOW_CACHE_TYPE=

# Set LANGFLOW_AUTO_LOGIN to false if you want to disable auto login
# and use the login form to login. LANGFLOW_SUPERUSER and LANGFLOW_SUPERUSER_PASSWORD
# must be set if AUTO_LOGIN is set to false
# Values: true, false
LANGFLOW_AUTO_LOGIN=

# SET LANGFLOW_ENABLE_SUPERUSER_CLI to false to disable
# superuser creation via the CLI
LANGFLOW_ENABLE_SUPERUSER_CLI=

# Superuser username
# Example: LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER=

# Superuser password
# Example: LANGFLOW_SUPERUSER_PASSWORD=123456
LANGFLOW_SUPERUSER_PASSWORD=

# Should store environment variables in the database
# Values: true, false
LANGFLOW_STORE_ENVIRONMENT_VARIABLES=

# Should enable the MCP composer feature in MCP projects
# Values: true, false
# Default: true
LANGFLOW_MCP_COMPOSER_ENABLED=

# STORE_URL
# Example: LANGFLOW_STORE_URL=https://api.orangeflow.example
# LANGFLOW_STORE_URL=

# DOWNLOAD_WEBHOOK_URL
#
# LANGFLOW_DOWNLOAD_WEBHOOK_URL=

# LIKE_WEBHOOK_URL
#
# LANGFLOW_LIKE_WEBHOOK_URL=

# Value must finish with slash /
#BACKEND_URL=http://localhost:7860/
BACKEND_URL=
# Preferred explicit public URL used for signed file/media links behind HTTPS or reverse proxies.
LANGFLOW_PUBLIC_BASE_URL=
# Production deployments should set the exact browser origin instead of using wildcard CORS.
LANGFLOW_CORS_ORIGINS=

# --- Gateway Provider Keys (optional) ---
# These are used by the built-in /v1/* gateway adapters when routing to upstream providers.
#
# Doubao / Ark
ARK_API_KEY=
ARK_API_BASE=
#
# DashScope (Wan / Qwen TTS)
DASHSCOPE_API_KEY=
#
# Google (Gemini / Veo)
GEMINI_API_KEY=
GOOGLE_API_KEY=
#
# Bing Image Search (Canvas Assistant: 电影镜头灵感)
BING_IMAGE_SEARCH_KEY=
# Optional override
BING_IMAGE_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/images/search
# Canvas Assistant inspiration (proxy/cache + vision analysis)
CANVAS_ASSISTANT_INSPIRATION_CACHE_DIR=
CANVAS_ASSISTANT_INSPIRATION_THUMB_MAX_BYTES=3145728
CANVAS_ASSISTANT_INSPIRATION_FULL_MAX_BYTES=12582912
CANVAS_ASSISTANT_INSPIRATION_VISION_MODEL=gemini-3-flash-preview
#
# OpenAI (Sora domestic proxy uses this in the gateway)
OPENAI_API_KEY=
SORA_API_BASE=
#
# Kling (Omni-Video / kling-video-o1)
KLING_API_KEY=
KLING_API_BASE=

# Vidu (viduq3-pro)
VIDU_API_KEY=
VIDU_API_BASE=

# --- Jimeng Visual CV (Smart HD) ---
# 即梦「智能超清」等 Visual CV 接口使用 AK/SK 鉴权（Region=cn-north-1, Service=cv）
JIMENG_CV_ACCESS_KEY=
JIMENG_CV_SECRET_KEY=
# Optional override
JIMENG_VISUAL_API_BASE=https://visual.volcengineapi.com
