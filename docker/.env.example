# Langflow 生产环境配置示例
# 复制此文件为 .env 并根据你的环境修改配置

# ============================================
# 基础配置
# ============================================

# Langflow 访问端口
LANGFLOW_PORT=7860

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# 数据库配置
# ============================================

# PostgreSQL 数据库配置
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=langflow
POSTGRES_PASSWORD=langflow_strong_password_change_this
POSTGRES_DB=langflow

# 对外暴露的 PostgreSQL 端口（可选，用于外部连接）
POSTGRES_PORT_EXTERNAL=5433

# ============================================
# 超级用户配置
# ============================================

# 超级管理员用户名和密码
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=admin_strong_password_change_this

# ============================================
# 安全配置
# ============================================

# 密钥 (必须更改为随机的强密钥!)
# 生成方法: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key-generate-with-openssl

# API Key 配置
API_KEY=
API_KEY_ENABLED=false

# 跳过自动登录
SKIP_AUTO_LOGIN=false

# ============================================
# 火山引擎 (豆包) 配置
# ============================================

# 火山引擎 API Key
VOLCENGINE_API_KEY=your_volcengine_api_key

# 火山引擎 ARK Endpoint (可选)
VOLCENGINE_ENDPOINT=

# ============================================
# 阿里云 (通义千问) 配置
# ============================================

# 阿里云 DashScope API Key
DASHSCOPE_API_KEY=your_dashscope_api_key

# ============================================
# 存储配置 (可选)
# ============================================

# 如果使用对象存储（如 AWS S3、阿里云 OSS）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=

# 阿里云 OSS 配置
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_ENDPOINT=
# OSS_BUCKET_NAME=

# ============================================
# 其他配置
# ============================================

# Langflow 配置目录
LANGFLOW_CONFIG_DIR=/app/langflow_config

# 数据目录
LANGFLOW_DATA_DIR=/app/data
